tasked.lol {
  tls {
    issuer acme {
      dir https://acme-v02.api.letsencrypt.org/directory
    }
  }

  encode zstd gzip
  root * /usr/share/caddy
  file_server

  handle /api/* {
    reverse_proxy api:3001
  }

  handle /ws* {
    reverse_proxy api:3001
  }

  handle {
    try_files {path} /index.html
    file_server
  }
}
