tasked.lol, www.tasked.lol {
  tls {
    issuer acme {
      ca https://acme.zerossl.com/v2/DV90
    }
  }

  encode zstd gzip
  root * /usr/share/caddy
  file_server

  handle /api/* {
    reverse_proxy api:3001
  }

  handle /ws* {
    reverse_proxy api:3001
  }

  handle {
    try_files {path} /index.html
    file_server
  }
}
