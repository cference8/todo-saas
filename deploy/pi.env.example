POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
DATABASE_URL=postgres://postgres:replace-with-a-strong-postgres-password@postgres:5432/todo_saas
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=https://tasked.lol
SERVER_ORIGIN=https://tasked.lol
GOOGLE_AUTH_ENABLED=true
GOOGLE_CLIENT_ID=replace-with-your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-oauth-client-secret
APPLE_AUTH_ENABLED=false
APPLE_CLIENT_ID=replace-with-your-apple-service-id
APPLE_TEAM_ID=replace-with-your-apple-team-id
APPLE_KEY_ID=replace-with-your-apple-key-id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-your-apple-private-key\n-----END PRIVATE KEY-----"
INVITE_EMAILS_ENABLED=false
INVITE_EMAIL_PROVIDER=resend
RESEND_API_KEY=replace-with-your-resend-api-key
INVITE_FROM_EMAIL=invites@tasked.lol
INVITE_FROM_NAME=Tasked
# Invite emails and password reset emails share this same Resend configuration.
PORT=3001
